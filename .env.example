# ── FylePro GST — environment ────────────────────────────────
# Copy to .env for local dev. On Railway set these as service variables.

# Server
PORT=8080
NODE_ENV=development

# Postgres (Railway provides DATABASE_URL automatically when you attach a PG plugin)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fylepro
# Set to "true" when connecting to Railway/managed PG that needs SSL
PGSSL=false

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# GSP / GST portal integration (per-client; leave blank to use JSON-only mode)
# Delivery mode resolved per gst_registration: 'json' (download) or 'api' (push via GSP)
GSP_BASE_URL=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_PROVIDER=stub
