# ── FylePro GST — environment ────────────────────────────────
# Copy to .env for local dev. On Railway set these as service variables.

# Server
PORT=8080
NODE_ENV=development

# Postgres. On Railway, add a variable reference from the app service to the
# Postgres service, usually DATABASE_URL=${{Postgres.DATABASE_URL}}.
# The app also accepts DATABASE_PRIVATE_URL, DATABASE_PUBLIC_URL, POSTGRES_URL,
# or PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE when Railway exposes those.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fylepro
# SSL: leave unset to auto-detect (ON for remote/managed DBs, OFF for localhost).
# Force with "true"/"false" only if you need to override.
# PGSSL=true

# Auth — MUST be a non-empty random string in production. If left blank the app
# falls back to an insecure dev secret (so login won't 500, but set this!).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Apply db/schema.sql automatically on boot (idempotent). Set "false" to disable.
RUN_MIGRATIONS_ON_BOOT=true

# GSP / GST portal integration (per-client; leave blank to use JSON-only mode)
# Delivery mode resolved per gst_registration: 'json' (download) or 'api' (push via GSP)
GSP_BASE_URL=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_PROVIDER=stub
